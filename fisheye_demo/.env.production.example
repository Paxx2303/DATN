# ============================================================
# FishEye8K — Production Environment (GCP)
# Dùng cho deploy trên GCE VM với Cloud SQL + GCS
# ============================================================

# ── Inference ────────────────────────────────────────────────
FISHEYE_DEFAULT_CONF=0.25
FISHEYE_DEFAULT_IOU=0.45
FISHEYE_DEVICE=0
FISHEYE_PRELOAD_MODEL=1
FISHEYE_MAX_UPLOAD_MB=256
FISHEYE_MAX_VIDEO_SECONDS=180

# ── Storage ──────────────────────────────────────────────────
FISHEYE_UPLOAD_DIR=/app/static/uploads
FISHEYE_RESULTS_DIR=/app/static/results
FISHEYE_RECENT_IMAGE_DB=/app/data/recent_images.sqlite3
FISHEYE_RECENT_IMAGE_LIMIT=100

# ── PostgreSQL (Cloud SQL) ───────────────────────────────────
# Option A: Cloud SQL Proxy (Unix socket) — khuyến nghị trên GCE
DATABASE_URL=postgresql://fisheye_user:CHANGE_ME@/fisheye_db?host=/cloudsql/PROJECT_ID:asia-southeast1:fisheye-db

# Option B: TCP trực tiếp (khi dùng Cloud SQL Auth Proxy port 5432)
# DATABASE_URL=postgresql://fisheye_user:CHANGE_ME@127.0.0.1:5432/fisheye_db

# ── Google Cloud Storage ─────────────────────────────────────
FISHEYE_CLOUD_STORAGE=1
GCS_BUCKET_NAME=fisheye-snapshots-CHANGE_ME
GCS_PROJECT_ID=CHANGE_ME_PROJECT_ID
FISHEYE_SNAPSHOT_TTL_HOURS=6
# Trên GCE VM dùng ADC (Application Default Credentials) — không cần key JSON
# GCS_CREDENTIALS_JSON=

# ── Alert thresholds ─────────────────────────────────────────
ALERT_THRESHOLD_TOTAL=15
ALERT_THRESHOLD_CAR=10
ALERT_THRESHOLD_BUS=3
ALERT_THRESHOLD_TRUCK=3
ALERT_THRESHOLD_PEDESTRIAN=8
ALERT_THRESHOLD_MOTORBIKE=12
ALERT_COOLDOWN_SECONDS=60

# ── External camera ──────────────────────────────────────────
FISHEYE_EXTERNAL_CAMERA_SOURCE_MODE=stream
FISHEYE_EXTERNAL_CAMERA_STREAM_URL=
FISHEYE_EXTERNAL_CAMERA_LIVE_INTERVAL=1.0
FISHEYE_EXTERNAL_CAMERA_LIMIT=1

# ── Gunicorn ─────────────────────────────────────────────────
WEB_CONCURRENCY=1
WEB_THREADS=4
WEB_TIMEOUT=300
