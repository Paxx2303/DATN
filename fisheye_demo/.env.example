# ============================================================
# FishEye8K Detection System — Environment Configuration
# Copy file này thành .env và điền giá trị thực
# ============================================================

# ── Inference defaults ───────────────────────────────────────
FISHEYE_DEFAULT_CONF=0.25
FISHEYE_DEFAULT_IOU=0.45

# ── Device ──────────────────────────────────────────────────
FISHEYE_DEVICE=cpu
# FISHEYE_DEVICE=0   # GPU index khi có CUDA

# ── Artifact storage ─────────────────────────────────────────
FISHEYE_RESULTS_DIR=static/results
FISHEYE_RECENT_IMAGE_DB=recent_images.sqlite3
FISHEYE_RECENT_IMAGE_LIMIT=100

# ── Fisheye defaults ─────────────────────────────────────────
FISHEYE_DEFAULT_STRENGTH=0.70
FISHEYE_DEFAULT_RADIUS=0.85
FISHEYE_DEFAULT_EFFECT=standard

# ── Model ────────────────────────────────────────────────────
# FISHEYE_MODEL_PATH=/path/to/best.pt
FISHEYE_PRELOAD_MODEL=1

# ── PostgreSQL (Cloud SQL) ───────────────────────────────────
# Local dev: dùng SQLite nếu không set DATABASE_URL
# DATABASE_URL=postgresql://user:password@localhost:5432/fisheye_db
# GCP Cloud SQL (Unix socket qua Cloud SQL Proxy):
# DATABASE_URL=postgresql://user:password@/fisheye_db?host=/cloudsql/PROJECT:REGION:INSTANCE

# ── Google Cloud Storage ─────────────────────────────────────
# Bật GCS upload (1=bật, 0=tắt)
FISHEYE_CLOUD_STORAGE=0
# GCS_BUCKET_NAME=fisheye-snapshots
# GCS_PROJECT_ID=your-gcp-project-id
# Số giờ giữ ảnh trên GCS trước khi xóa (mặc định 6h)
FISHEYE_SNAPSHOT_TTL_HOURS=6
# Service account key JSON (nếu không dùng ADC)
# GCS_CREDENTIALS_JSON={"type":"service_account",...}

# ── Alert thresholds ─────────────────────────────────────────
ALERT_THRESHOLD_TOTAL=15
ALERT_THRESHOLD_CAR=10
ALERT_THRESHOLD_BUS=3
ALERT_THRESHOLD_TRUCK=3
ALERT_THRESHOLD_PEDESTRIAN=8
ALERT_THRESHOLD_MOTORBIKE=12
ALERT_COOLDOWN_SECONDS=60

# ── External camera ──────────────────────────────────────────
FISHEYE_EXTERNAL_CAMERA_URL=https://camera.0511.vn/camera.html
FISHEYE_EXTERNAL_CAMERA_SOURCE_MODE=snapshot
# FISHEYE_EXTERNAL_CAMERA_STREAM_URL=rtsp://...
FISHEYE_EXTERNAL_CAMERA_LIVE_INTERVAL=1.0
FISHEYE_EXTERNAL_CAMERA_LIMIT=1
